# Base URL of the deployed apps/server API. Defaults to http://localhost:4000
# if unset (see lib/api/client.ts), which is fine for local dev.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Cache-busting build id: when this differs from what's stored in the
# client's localStorage, every lca:-prefixed key is wiped on next load (see
# lib/storage/store.ts). The Docker build sets this automatically to a build
# timestamp (see apps/web/Dockerfile) - no need to set it by hand. Left unset,
# it defaults to a fixed "dev" value, so local dev never triggers a wipe.
# NEXT_PUBLIC_APP_VERSION=
