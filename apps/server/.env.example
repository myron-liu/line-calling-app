# Used by the running server (src/db/client.ts): Supabase's Transaction pooler,
# port 6543 (Project Settings → Database → Connection string → Transaction).
# `prepare: false` is set for you in client.ts since pgbouncer transaction mode
# doesn't support prepared statements.
DATABASE_URL=postgres://postgres.xxxxxxxxxxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# `bun run db:migrate` needs a plain session connection instead (DDL doesn't
# work reliably through the transaction pooler) — override DATABASE_URL for
# that one command, e.g.:
#   DATABASE_URL=postgres://postgres.xxxxxxxxxxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres bun run db:migrate
# (same host, Session pooler on port 5432, or the direct connection string).

PORT=4000

# The web app's origin(s). Comma-separated is NOT supported by the current CORS
# helper (src/http.ts) — set to your single deployed web origin, or "*" for local dev.
CORS_ORIGIN=*
